<?xml version="1.0"?>

<robot name="swerve_sentry" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <!-- Take forward as +x -->

  <xacro:property name="lidar_angle" value="${pi / 4}" />

  <link name="left_livox_frame"/>
  <link name="right_livox_frame"/>
  <link name="main_gimbal_link"/>

  <joint name="gimbal_to_left_livox" type="fixed">
    <parent link="main_gimbal_link"/>
    <child link="left_livox_frame"/>
    <origin xyz="0.0 0.180765 0.0" rpy="0 0 ${pi / 2}"/>
  </joint>

  <joint name="gimbal_to_right_livox" type="fixed">
    <parent link="main_gimbal_link"/>
    <child link="right_livox_frame"/>
    <origin xyz="0.0 -0.180765 0.0" rpy="0 0 ${-pi / 2}"/>
  </joint>

  <!-- Keep this legacy compatibility link for TF consumers during migration. -->
  <link name="main_gimbal_odom"/>

  <joint name="gimbal_link_to_gimbal_odom" type="floating">
    <parent link="main_gimbal_link"/>
    <child link="main_gimbal_odom"/>
  </joint>

  <link name="base_link"/>

  <joint name="gimbal_to_base" type="continuous">
    <parent link="main_gimbal_link"/>
    <child link="base_link"/>
    <origin xyz="0 0 -0.34264" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="high_main_gimbal_link"/>
  <joint name="high_joint" type="fixed">
    <parent link="main_gimbal_link"/>
    <child link="high_main_gimbal_link"/>
    <origin xyz="0 0 -0.34264" rpy="0 0 0"/>
  </joint>

</robot>
